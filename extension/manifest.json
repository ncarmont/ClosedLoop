{
  "manifest_version": 3,
  "name": "CloseLoop",
  "version": "0.3.0",
  "description": "Give your AI coding agent your real browser. Beta/experimental.",
  "permissions": [
    "activeTab",
    "tabs",
    "debugger",
    "scripting",
    "storage",
    "alarms",
    "sidePanel"
  ],
  "host_permissions": [
    "<all_urls>",
    "http://localhost:9009/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "CloseLoop"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  }
}
